# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Production

# Application URLs
ASPNETCORE_URLS=http://+:8080
ASPNETCORE_HTTP_PORTS=8080

# Database Configuration
# For SQLite, path will be: /app/data/MyDogSpace.db
DB_PATH=/app/data/MyDogSpace.db

# JWT Configuration
# IMPORTANT: Generate a strong secret key for production!
# Use at least 64 characters for security
# Example generation: openssl rand -base64 64
JWT_SECRET=my_top_secret_super_puper_incredible_long_key_for_my_dog_space_application_please_change_this_in_production

# Logging
LOG_LEVEL=Information

# CORS Settings (if needed)
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
